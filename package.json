{
  "name": "mohamed-shawki-erp-production",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev --port 3040",
    "build": "prisma generate && next build",
    "start": "next start --port 3040",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:push": "prisma db push",
    "audit:production": "node scripts/audit-production-readiness.js",
    "check:production-env": "node scripts/check-env-production.js",
    "check:auth": "node scripts/check-auth-permissions.js",
    "check:mojibake": "node scripts/check-mojibake.js",
    "migrate:legacy": "node scripts/migrate-legacy-db.mjs",
    "ensure:city-projects": "node scripts/ensure-city-application-projects.mjs --apply",
    "ensure:admin": "node scripts/ensure-admin-user.mjs"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "csv-parse": "^6.2.1",
    "exceljs": "^4.4.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "prisma": "6.19.3",
    "recharts": "^3.8.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.6",
    "postcss": "8.5.15",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3"
  },
  "overrides": {
    "postcss": "$postcss",
    "uuid": "^11.1.1"
  }
}
