# PostgreSQL connection used by Prisma. Replace every placeholder.
DATABASE_URL="postgresql://ERP_USER:CHANGE_ME@127.0.0.1:5432/mohamed_shawki_erp?schema=public"

# Generate at least 32 random bytes. Never commit the real value.
AUTH_SECRET="REPLACE_WITH_A_LONG_RANDOM_SECRET"

NEXT_PUBLIC_APP_NAME="MOHAMED SHAWKI ERP"
APP_URL="https://erp.example.com"
UPLOAD_DIR="public/uploads"

# Used only by docker-compose.yml.
POSTGRES_DB="mohamed_shawki_erp"
POSTGRES_USER="erp_user"
POSTGRES_PASSWORD="REPLACE_WITH_A_STRONG_DATABASE_PASSWORD"
