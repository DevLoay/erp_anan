generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

enum Role {
  ADMIN
  OPERATION_MANAGER
  SUPERVISOR
  ACCOUNTANT
  HR
  VIEWER
}

enum RecordStatus {
  ACTIVE
  INACTIVE
  PENDING
  APPROVED
  REJECTED
  LOCKED
  CANCELLED
  DEDUCTED
  PARTIALLY_DEDUCTED
}

enum DriverStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum VehicleStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  ACCIDENT
  INACTIVE
}

enum PayrollStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  PAID
  LOCKED
}

enum Severity {
  CRITICAL
  WARNING
  INFO
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String?
  role         Role     @default(VIEWER)
  cityId       String?
  driverId     String?
  supervisorId String?
  cityScope    String?
  projectScope String?
  status       String   @default("active")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  city                 City?                    @relation(fields: [cityId], references: [id])
  driver               Driver?                  @relation("UserDriverAccount", fields: [driverId], references: [id])
  supervisor           Supervisor?              @relation("UserSupervisorAccount", fields: [supervisorId], references: [id])
  approvedPayrollRuns  PayrollRun[]             @relation("PayrollRunApprovedBy")
  createdImportBatches ApplicationImportBatch[] @relation("ApplicationImportBatchCreatedBy")
  approvedImportBatches ApplicationImportBatch[] @relation("ApplicationImportBatchApprovedBy")
  payrollAdjustments   PayrollAdjustment[]      @relation("PayrollAdjustmentCreatedBy")
  createdAdvances       Advance[]                @relation("AdvanceCreatedBy")
  approvedAdvances      Advance[]                @relation("AdvanceApprovedBy")
  attendanceRecords    AttendanceRecord[]       @relation("UserAttendanceRecords")
  auditLogs            AuditLog[]               @relation("AuditLogUser")
  approvedAccountUsages AccountUsage[]           @relation("AccountUsageApprovedBy")
}

model City {
  id        String       @id @default(cuid())
  nameAr    String
  nameEn    String?
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  users               User[]
  projects            Project[]
  supervisors         Supervisor[]
  drivers             Driver[]
  vehicles            Vehicle[]
  reports             DailyReport[]
  tasks               Task[]
  applicationAccounts ApplicationAccount[]
  applicationProjects ApplicationProject[]
  payrollSettings     ApplicationPayrollSetting[]
  payrollRuns         PayrollRun[]
  financeEntries      FinanceEntry[]
  keetaPayrollPlans    KeetaPayrollPlan[]
  keetaRankRecords    KeetaRankRecord[]
  keetaPerformanceRecords KeetaPerformanceRecord[]
  keetaInvoiceRecords KeetaInvoiceRecord[]
  hungerStationDailyPerformanceRecords HungerStationDailyPerformanceRecord[]
  hungerStationInvoiceRecords HungerStationInvoiceRecord[]
  hungerStationAccountUsages HungerStationAccountUsage[]
  accountUsages       AccountUsage[]
  advances            Advance[]
}

model Project {
  id        String       @id @default(cuid())
  name      String
  appName   String?
  cityId    String?
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  city                City?                @relation(fields: [cityId], references: [id])
  drivers             Driver[]
  accounts            ApplicationAccount[]
  reports             DailyReport[]
  payrolls            Payroll[]
  applicationProjects ApplicationProject[]
}

model Supervisor {
  id        String       @id @default(cuid())
  name      String
  phone     String?
  email     String?
  cityId    String?
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  city    City?    @relation(fields: [cityId], references: [id])
  users   User[]   @relation("UserSupervisorAccount")
  drivers Driver[]
  tasks   Task[]
  notifications Notification[]
  advances Advance[]
  attendanceRecords AttendanceRecord[]
}

model Driver {
  id                String       @id @default(cuid())
  internalCode      String       @unique
  driverCode        String?
  name              String
  actualName        String?
  phone             String?
  mobile            String?
  nationalId        String?
  nationality       String?
  cityId            String?
  projectId         String?
  supervisorId      String?
  vehicleId         String?
  vehicleOwnershipType String   @default("no_vehicle")
  accountId         String?
  status            DriverStatus @default(ACTIVE)
  contractType      String?
  sponsorshipType   String?
  accommodationType String?
  housingStatus     String?
  source            String?
  needsReview       Boolean      @default(false)
  joinDate          DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  city                City?                  @relation(fields: [cityId], references: [id])
  project             Project?               @relation(fields: [projectId], references: [id])
  supervisor          Supervisor?            @relation(fields: [supervisorId], references: [id])
  vehicle             Vehicle?               @relation("DriverVehicle", fields: [vehicleId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  account             ApplicationAccount?    @relation("DriverPrimaryAccount", fields: [accountId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  userAccounts        User[]                 @relation("UserDriverAccount")
  currentVehicles     Vehicle[]              @relation("VehicleCurrentDriver")
  applicationAccounts ApplicationAccount[]   @relation("ApplicationAccountAssignedDriver")
  vehicleAssignments  VehicleAssignment[]
  reports             DailyReport[]
  advances            Advance[]
  deductions          Deduction[]
  violations          Violation[]
  payrolls            Payroll[]
  payrollItems        PayrollItem[]
  fuelRecords         FuelRecord[]
  documents           DriverDocument[]
  contracts           DriverContract[]
  housingRecords      DriverHousing[]
  warnings            DriverWarning[]
  attendanceRecords   AttendanceRecord[]
  shifts              Shift[]
  financeEntries      FinanceEntry[]
  importRows          ApplicationImportRow[]
  tasks               Task[]
  notifications       Notification[]
  keetaRankRecords    KeetaRankRecord[]
  keetaPerformanceRecords KeetaPerformanceRecord[]
  keetaInvoiceRecords KeetaInvoiceRecord[]
  keetaInvoiceDetailRecords KeetaInvoiceDetailRecord[]
  hungerStationDailyPerformanceRecords HungerStationDailyPerformanceRecord[]
  hungerStationInvoiceRecords HungerStationInvoiceRecord[]
  hungerStationAccountUsages HungerStationAccountUsage[]
  ownedAccountUsages  AccountUsage[]            @relation("AccountUsageOwnerDriver")
  actualAccountUsages AccountUsage[]            @relation("AccountUsageActualDriver")

  @@index([driverCode])
  @@index([nationalId])
  @@index([cityId, projectId, supervisorId])
}

model Vehicle {
  id              String        @id @default(cuid())
  vehicleCode     String?
  plateAr         String?
  plateArabic     String?
  plateEn         String        @unique
  plateEnglish    String?
  brand           String?
  model           String?
  year            Int?
  ownershipType   String        @default("company")
  rentalCompany   String?
  rentalCompanyId String?
  dailyRent       Decimal       @default(0) @db.Decimal(12, 2)
  monthlyRent     Decimal       @default(0)
  status          VehicleStatus @default(AVAILABLE)
  currentDriverId String?
  cityId          String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  city          City?               @relation(fields: [cityId], references: [id])
  currentDriver Driver?             @relation("VehicleCurrentDriver", fields: [currentDriverId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  rentalCompanyRef RentalCompany? @relation("VehicleRentalCompany", fields: [rentalCompanyId], references: [id], onDelete: SetNull)
  drivers       Driver[]            @relation("DriverVehicle")
  assignments   VehicleAssignment[]
  payrollItems  PayrollItem[]
  fuelRecords   FuelRecord[]
  violations    Violation[]
  deductions    Deduction[]

  @@index([plateAr])
  @@index([plateArabic])
  @@index([plateEnglish])
  @@index([vehicleCode])
  @@index([currentDriverId])
  @@index([rentalCompanyId])
}

model Application {
  id          String       @id @default(cuid())
  code        String       @unique
  name        String
  description String?
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  projects        ApplicationProject[]
  accounts        ApplicationAccount[]
  invoiceSettings ApplicationInvoiceSetting[]
  rankSettings    ApplicationRankSetting[]
  payrollSettings ApplicationPayrollSetting[]
  importTemplates ApplicationImportTemplate[]
  importBatches   ApplicationImportBatch[]
  payrollRuns     PayrollRun[]
  financeEntries  FinanceEntry[]
  dailyReports    DailyReport[]
  templateConfigs TemplateConfig[]
  payrollFieldRules PayrollFieldRule[]
  hungerStationDailyPerformanceRecords HungerStationDailyPerformanceRecord[]
  hungerStationInvoiceRecords HungerStationInvoiceRecord[]
  hungerStationAccountUsages HungerStationAccountUsage[]
  accountUsages AccountUsage[]
}

model ApplicationProject {
  id            String       @id @default(cuid())
  applicationId String
  projectId     String?
  cityId        String?
  code          String       @unique
  name          String
  monthlyTarget Int?
  dailyTarget   Int?
  status        RecordStatus @default(ACTIVE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  application     Application                 @relation(fields: [applicationId], references: [id])
  project         Project?                    @relation(fields: [projectId], references: [id])
  city            City?                       @relation(fields: [cityId], references: [id])
  accounts        ApplicationAccount[]
  invoiceSettings ApplicationInvoiceSetting[]
  rankSettings    ApplicationRankSetting[]
  payrollSettings ApplicationPayrollSetting[]
  importTemplates ApplicationImportTemplate[]
  importBatches   ApplicationImportBatch[]
  payrollRuns     PayrollRun[]
  financeEntries  FinanceEntry[]
  dailyReports    DailyReport[]
  invoices        Invoice[]
  advances        Advance[]
  templateConfigs TemplateConfig[]
  payrollFieldRules PayrollFieldRule[]
  keetaPayrollPlans KeetaPayrollPlan[]
  keetaRankRecords KeetaRankRecord[]
  keetaPerformanceRecords KeetaPerformanceRecord[]
  keetaInvoiceRecords KeetaInvoiceRecord[]
  keetaInvoiceDetailRecords KeetaInvoiceDetailRecord[]
  hungerStationDailyPerformanceRecords HungerStationDailyPerformanceRecord[]
  hungerStationInvoiceRecords HungerStationInvoiceRecord[]
  hungerStationAccountUsages HungerStationAccountUsage[]
  accountUsages AccountUsage[]

  @@index([applicationId])
  @@index([projectId])
  @@index([cityId])
}

model ApplicationInvoiceSetting {
  id                   String       @id @default(cuid())
  applicationId        String
  applicationProjectId String?
  name                 String
  invoiceType          String?
  requiredColumns      Json?
  optionalColumns      Json?
  columnMapping        Json?
  calculationRules     Json?
  deductionRules       Json?
  bonusRules           Json?
  status               RecordStatus @default(ACTIVE)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  application        Application         @relation(fields: [applicationId], references: [id])
  applicationProject ApplicationProject? @relation(fields: [applicationProjectId], references: [id])

  @@index([applicationId])
  @@index([applicationProjectId])
}

model ApplicationRankSetting {
  id                   String       @id @default(cuid())
  applicationId        String
  applicationProjectId String?
  name                 String
  rankType             String?
  minimumOrders        Int?
  onTimeRule           Json?
  cancellationRule     Json?
  rejectionRule        Json?
  workingHoursRule     Json?
  bonusRule            Json?
  deductionRule        Json?
  levelOutput          Json?
  status               RecordStatus @default(ACTIVE)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  application        Application         @relation(fields: [applicationId], references: [id])
  applicationProject ApplicationProject? @relation(fields: [applicationProjectId], references: [id])

  @@index([applicationId])
  @@index([applicationProjectId])
}

model ApplicationPayrollSetting {
  id                   String       @id @default(cuid())
  applicationId        String
  applicationProjectId String?
  cityId               String?
  name                 String
  basicSalary          Decimal?     @db.Decimal(12, 2)
  targetOrders         Int?
  extraOrderPrice      Decimal?     @db.Decimal(12, 2)
  levelRules           Json?
  bonusRules           Json?
  deductionRules       Json?
  carRentRule          Json?
  salaryCalculationSource String       @default("payroll_plan")
  useKeetaInvoiceAsSalaryBase Boolean  @default(false)
  status               RecordStatus @default(ACTIVE)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  application        Application         @relation(fields: [applicationId], references: [id])
  applicationProject ApplicationProject? @relation(fields: [applicationProjectId], references: [id])
  city               City?               @relation(fields: [cityId], references: [id])
  payrollRuns        PayrollRun[]

  @@index([applicationId])
  @@index([applicationProjectId])
  @@index([cityId])
}

model ApplicationImportTemplate {
  id                   String       @id @default(cuid())
  applicationId        String?
  applicationProjectId String?
  name                 String
  fileType             String
  requiredColumns      Json?
  optionalColumns      Json?
  columnMapping        Json?
  sampleFileUrl        String?
  status               RecordStatus @default(ACTIVE)
  lastUsedAt           DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  application        Application?             @relation(fields: [applicationId], references: [id])
  applicationProject ApplicationProject?      @relation(fields: [applicationProjectId], references: [id])
  batches            ApplicationImportBatch[]

  @@index([applicationId])
  @@index([applicationProjectId])
}

model ApplicationImportBatch {
  id                   String    @id @default(cuid())
  applicationId        String?
  applicationProjectId String?
  templateId           String?
  projectId            String?
  cityId               String?
  fileType             String
  fileName             String?
  sourceFileName       String?
  importType           String?
  month                String?
  periodStart          DateTime?
  periodEnd            DateTime?
  status               String    @default("preview")
  sheetNames           Json?
  totalRows            Int       @default(0)
  validRows            Int       @default(0)
  invalidRows          Int       @default(0)
  duplicateRows        Int       @default(0)
  missingDrivers       Int       @default(0)
  unlinkedAccounts     Int       @default(0)
  unmatchedRows        Int       @default(0)
  previewData          Json?
  matchedColumns       Json?
  errorRows            Json?
  uploadedBy           String?
  uploadedAt           DateTime  @default(now())
  createdById          String?
  approvedById         String?
  approvedAt           DateTime?
  lockedAt             DateTime?
  committedAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  application        Application?               @relation(fields: [applicationId], references: [id])
  applicationProject ApplicationProject?        @relation(fields: [applicationProjectId], references: [id])
  template           ApplicationImportTemplate? @relation(fields: [templateId], references: [id])
  createdBy          User?                      @relation("ApplicationImportBatchCreatedBy", fields: [createdById], references: [id])
  approvedBy         User?                      @relation("ApplicationImportBatchApprovedBy", fields: [approvedById], references: [id])
  rows               ApplicationImportRow[]
  keetaRankRecords   KeetaRankRecord[]
  keetaPerformanceRecords KeetaPerformanceRecord[]
  keetaInvoiceRecords KeetaInvoiceRecord[]
  keetaInvoiceDetailRecords KeetaInvoiceDetailRecord[]
  hungerStationDailyPerformanceRecords HungerStationDailyPerformanceRecord[]
  hungerStationInvoiceRecords HungerStationInvoiceRecord[]

  @@index([applicationId])
  @@index([applicationProjectId])
  @@index([projectId])
  @@index([cityId])
  @@index([templateId])
  @@index([importType, month])
  @@index([createdById])
  @@index([approvedById])
  @@index([periodStart, periodEnd])
  @@index([status, createdAt])
}

model ApplicationImportRow {
  id                   String   @id @default(cuid())
  batchId              String
  rowNumber            Int
  rawData              Json
  mappedData           Json?
  isValid              Boolean  @default(false)
  errorType            String?
  errorMessage         String?
  driverId             String?
  applicationAccountId String?
  status               String   @default("pending")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  batch              ApplicationImportBatch @relation(fields: [batchId], references: [id])
  driver             Driver?                @relation(fields: [driverId], references: [id])
  applicationAccount ApplicationAccount?    @relation(fields: [applicationAccountId], references: [id])

  @@unique([batchId, rowNumber])
  @@index([driverId])
  @@index([applicationAccountId])
  @@index([status])
}

model TemplateConfig {
  id                         String   @id @default(cuid())
  key                        String   @unique
  nameAr                     String
  nameEn                     String
  projectId                  String?
  applicationId              String?
  applicationProjectId       String?
  scope                      String
  importType                 String
  enabled                    Boolean  @default(true)
  showInGlobalImports        Boolean  @default(false)
  showInProjectImports       Boolean  @default(true)
  showInInvoices             Boolean  @default(false)
  showInPayroll              Boolean  @default(false)
  showInReports              Boolean  @default(false)
  showInManagementReports    Boolean  @default(false)
  showInApplicationCenter    Boolean  @default(false)
  affectsPayroll             Boolean  @default(false)
  affectsInvoices            Boolean  @default(false)
  affectsReports             Boolean  @default(false)
  affectsRank                Boolean  @default(false)
  allowedRoles               Json?
  requiredColumns            Json?
  optionalColumns            Json?
  matchingKeys               Json?
  route                      String?
  sortOrder                  Int      @default(0)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  application        Application?        @relation(fields: [applicationId], references: [id])
  applicationProject ApplicationProject? @relation(fields: [applicationProjectId], references: [id])

  @@index([projectId])
  @@index([applicationId])
  @@index([applicationProjectId])
  @@index([scope, importType])
  @@index([enabled, sortOrder])
}

model KeetaRankRecord {
  id                              String   @id @default(cuid())
  projectId                       String   @default("keeta")
  applicationProjectId            String?
  driverId                        String?
  applicationAccountId            String?
  courierId                       String
  courierName                     String?
  cityId                          String?
  month                           String?
  periodStart                     DateTime?
  periodEnd                       DateTime?
  currentEstimatedLevel           String?
  currentEstimatedRanking         Decimal? @db.Decimal(12, 2)
  courierRankingPercentile        Decimal? @db.Decimal(12, 4)
  currentScoreForForcedAssignment Decimal? @db.Decimal(12, 4)
  currentEstimatedRewardAmount    Decimal? @db.Decimal(12, 2)
  onTimeRate                      Decimal? @db.Decimal(8, 4)
  orderCompletionRate             Decimal? @db.Decimal(8, 4)
  dropOffNotEarlyRate             Decimal? @db.Decimal(8, 4)
  orderVolume                     Int?
  rawData                         Json?
  importBatchId                   String?
  status                          String   @default("Approved")
  approvedBy                      String?
  approvedAt                      DateTime?
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt

  applicationProject ApplicationProject?      @relation(fields: [applicationProjectId], references: [id])
  driver             Driver?                  @relation(fields: [driverId], references: [id])
  applicationAccount ApplicationAccount?      @relation(fields: [applicationAccountId], references: [id])
  city               City?                    @relation(fields: [cityId], references: [id])
  importBatch        ApplicationImportBatch?  @relation(fields: [importBatchId], references: [id])

  @@index([projectId, month])
  @@index([applicationProjectId])
  @@index([driverId])
  @@index([applicationAccountId])
  @@index([courierId])
  @@index([cityId])
  @@index([status])
  @@index([periodStart, periodEnd])
}

model KeetaPerformanceRecord {
  id                                  String   @id @default(cuid())
  projectId                           String   @default("keeta")
  applicationProjectId                String?
  driverId                            String?
  applicationAccountId                String?
  courierId                           String
  courierFirstName                    String?
  courierLastName                     String?
  supervisorName                      String?
  vehicleType                         String?
  cityId                              String?
  reportDate                          DateTime
  month                               String?
  periodStart                         DateTime?
  periodEnd                           DateTime?
  shiftAttendanceSummary              String?
  onShift                             Boolean?
  validDay                            Boolean?
  courierAppOnlineTime                Decimal? @db.Decimal(10, 2)
  validOnlineTime                     Decimal? @db.Decimal(10, 2)
  peakOnlineHours                     Decimal? @db.Decimal(10, 2)
  acceptedTasks                       Int?
  tasksWithRestaurantArrivals         Int?
  deliveredTasks                      Int?
  largeOrderTasksCompleted            Int?
  rejectedTasks                       Int?
  rejectedTasksCourier                Int?
  rejectedTasksAuto                   Int?
  cancellationRateFromDeliveryIssues  Decimal? @db.Decimal(8, 4)
  orderCompletionRateNonDelivery      Decimal? @db.Decimal(8, 4)
  onTimeRate                          Decimal? @db.Decimal(8, 4)
  largeOrderOnTimeRate                Decimal? @db.Decimal(8, 4)
  avgDeliveryTime                     Decimal? @db.Decimal(10, 2)
  deliveredOrdersOver55MinPercent     Decimal? @db.Decimal(8, 4)
  overdueOrderTasks                   Int?
  severelyOverdueOrderTasks           Int?
  rawData                             Json?
  importBatchId                       String?
  status                              String   @default("Approved")
  approvedBy                          String?
  approvedAt                          DateTime?
  createdAt                           DateTime @default(now())
  updatedAt                           DateTime @updatedAt

  applicationProject ApplicationProject?     @relation(fields: [applicationProjectId], references: [id])
  driver             Driver?                 @relation(fields: [driverId], references: [id])
  applicationAccount ApplicationAccount?     @relation(fields: [applicationAccountId], references: [id])
  city               City?                   @relation(fields: [cityId], references: [id])
  importBatch        ApplicationImportBatch? @relation(fields: [importBatchId], references: [id])

  @@index([projectId, month])
  @@index([applicationProjectId])
  @@index([driverId])
  @@index([applicationAccountId])
  @@index([courierId])
  @@index([cityId])
  @@index([reportDate])
  @@index([status])
  @@index([periodStart, periodEnd])
}

model KeetaInvoiceRecord {
  id                         String   @id @default(cuid())
  projectId                  String   @default("keeta")
  applicationProjectId       String?
  driverId                   String?
  applicationAccountId       String?
  courierId                  String
  courierName                String?
  partnerId                  String?
  partnerName                String?
  billingCycle               String?
  cityId                     String?
  month                      String?
  periodStart                DateTime?
  periodEnd                  DateTime?
  isValid                    Boolean?
  reason                     String?
  onlineDaysValid            Decimal? @db.Decimal(10, 2)
  dailyOnlineHoursValid      Decimal? @db.Decimal(10, 2)
  dailyOnlineHoursPeakValid  Decimal? @db.Decimal(10, 2)
  deliveredOrders            Int?
  orderBasedPricing          Decimal? @db.Decimal(12, 2)
  distanceFromPriceIncrease  Decimal? @db.Decimal(12, 2)
  validDaCapacityIncentives  Decimal? @db.Decimal(12, 2)
  experienceIncentive        Decimal? @db.Decimal(12, 2)
  dxgy                       Decimal? @db.Decimal(12, 2)
  subsidy                    Decimal? @db.Decimal(12, 2)
  activitiesAndOtherRewards  Decimal? @db.Decimal(12, 2)
  deduction                  Decimal? @db.Decimal(12, 2)
  foodCompensation           Decimal? @db.Decimal(12, 2)
  registrationServiceFee     Decimal? @db.Decimal(12, 2)
  otherAdjustment            Decimal? @db.Decimal(12, 2)
  tipsExcludingTax           Decimal? @db.Decimal(12, 2)
  tgaDeductionVatExcluded    Decimal? @db.Decimal(12, 2)
  totalPayableAmount         Decimal? @db.Decimal(12, 2)
  rawData                    Json?
  invoiceBatchId             String?
  status                     String   @default("Approved")
  approvedBy                 String?
  approvedAt                 DateTime?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  applicationProject ApplicationProject?     @relation(fields: [applicationProjectId], references: [id])
  driver             Driver?                 @relation(fields: [driverId], references: [id])
  applicationAccount ApplicationAccount?     @relation(fields: [applicationAccountId], references: [id])
  city               City?                   @relation(fields: [cityId], references: [id])
  invoiceBatch       ApplicationImportBatch? @relation(fields: [invoiceBatchId], references: [id])

  @@index([projectId, month])
  @@index([applicationProjectId])
  @@index([driverId])
  @@index([applicationAccountId])
  @@index([courierId])
  @@index([cityId])
  @@index([invoiceBatchId])
  @@index([status])
  @@index([periodStart, periodEnd])
}

model KeetaInvoiceDetailRecord {
  id                       String   @id @default(cuid())
  projectId                String   @default("keeta")
  applicationProjectId     String?
  invoiceBatchId           String?
  driverId                 String?
  applicationAccountId     String?
  courierId                String
  courierName              String?
  partnerId                String?
  partnerName              String?
  billingCycle             String?
  transactionType          String?
  businessId               String?
  note                     String?
  feeType                  String?
  detailAmount             Decimal? @db.Decimal(12, 2)
  totalPayableAmount       Decimal? @db.Decimal(12, 2)
  deliveryDistance         Decimal? @db.Decimal(12, 2)
  ticketId                 String?
  violationId              String?
  violationType            String?
  punishmentMethods        String?
  timeOfFaceVerification   String?
  faceVerificationResult   String?
  rawData                  Json?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  applicationProject ApplicationProject?     @relation(fields: [applicationProjectId], references: [id])
  invoiceBatch       ApplicationImportBatch? @relation(fields: [invoiceBatchId], references: [id])
  driver             Driver?                 @relation(fields: [driverId], references: [id])
  applicationAccount ApplicationAccount?     @relation(fields: [applicationAccountId], references: [id])

  @@index([projectId])
  @@index([applicationProjectId])
  @@index([invoiceBatchId])
  @@index([driverId])
  @@index([applicationAccountId])
  @@index([courierId])
  @@index([violationType])
  @@index([feeType])
}

model ApplicationAccount {
  id                   String       @id @default(cuid())
  appName              String
  username             String       @unique
