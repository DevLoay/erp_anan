function escapeRegex(value: string) {
  return value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
}

function replaceTrimmed(input: string, trimmed: string, replacement: string) {
  const start = input.indexOf(trimmed);
  if (start < 0) return replacement;
  return input.slice(0, start) + replacement + input.slice(start + trimmed.length);
}

function translateSegment(segment: string, language: ErpLanguage): string {
  if (language === "ar") return segment;
  const trimmed = segment.trim();
  if (!trimmed) return segment;

  const exact = TEXT_MAP[trimmed]?.en;
  if (exact) return replaceTrimmed(segment, trimmed, exact);

  if (trimmed.startsWith("فتح ")) {
    const rest = trimmed.slice(4).trim();
    const translatedRest = TEXT_MAP[rest]?.en;
    if (translatedRest) return replaceTrimmed(segment, trimmed, "Open " + translatedRest);
  }

  const dynamicRules: Array<[RegExp, (...parts: string[]) => string]> = [
    [/^متبقي (\d+) يوم$/, (_all, days) => `${days} days left`],
    [/^منتهي منذ (\d+) يوم$/, (_all, days) => `Expired ${days} days ago`],
    [/^ينتهي اليوم$/, () => "Expires today"],
    [/^حذف مستند (.+)؟$/, (_all, name) => `Delete document ${name}?`],
    [/^تأكيد ربط (\d+) مندوب بالمشرف المحدد؟$/, (_all, count) => `Confirm assigning ${count} drivers to the selected supervisor?`],
    [/^تم تحديث (\d+) مندوب\. المتجاوز: (\d+)$/, (_all, updated, skipped) => `Updated ${updated} drivers. Skipped: ${skipped}`],
  ];

  for (const [regex, build] of dynamicRules) {
    const match = trimmed.match(regex);
    if (match) return replaceTrimmed(segment, trimmed, build(...match));
  }

  return segment;
}

export function translateText(input: string, language: ErpLanguage): string {
  if (language === "ar") return input;
  if (!input || !/[\u0600-\u06FF]/.test(input)) return input;

  const trimmed = input.trim();
  if (!trimmed) return input;

  const direct = translateSegment(input, language);
  if (direct !== input) return direct;

  const separators = [" > ", " / ", "  /  ", " | ", " — ", " - "];
  for (const sep of separators) {
    if (input.includes(sep)) {
      const translated = input.split(sep).map((part) => translateSegment(part, language)).join(sep);
      if (translated !== input) return translated;
    }
  }

  let output = input;
  const keys = Object.keys(TEXT_MAP).filter((key) => key.length >= 3).sort((a, b) => b.length - a.length);
  for (const key of keys) {
    if (!output.includes(key)) continue;
    output = output.replace(new RegExp(escapeRegex(key), "g"), TEXT_MAP[key].en);
  }

  return output;
}
